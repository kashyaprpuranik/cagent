# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
venv/
.venv/

# Node
node_modules/
dist/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Environment
.env
.env.local

# Database
*.db
*.sqlite

# Logs
*.log

# MITM proxy CA (contains private key) — addon script is tracked
configs/mitm/*.pem

# mTLS certs (generated by gen_mtls_certs.sh)
configs/mtls/*.pem

# Runtime config overrides (generated by warden, persists across restarts)
runtime_config.json

# E2E test config backups (created by test.sh before runtime mutation)
configs/**/.*.bak
configs/.cagent.yaml.bak

# OS
.DS_Store
Thumbs.db
