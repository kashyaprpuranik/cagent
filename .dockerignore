# Ignore everything by default
*

# Allow workspace plumbing (warden frontend build)
!package.json
!package-lock.json

# Allow warden (includes frontend source)
!services/warden/
!services/warden/**

# Allow cell container files
!cell.Dockerfile
!cell_entrypoint.sh
!cell-requirements/
!entrypoint.sh
!configs/
!configs/**
!scripts/
!scripts/**

# Re-exclude node_modules and build artifacts everywhere
**/node_modules
**/dist
**/.git
**/*.md
**/.env*
**/.vscode
**/.idea
**/__pycache__
**/*.pyc
**/e2e
