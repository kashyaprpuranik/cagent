{
  "name": "code-review",
  "description": "Code review and PR agent — GitHub, GitLab, package registries",
  "security": {
    "runtime_policy": "hardened",
    "seccomp_profile": "hardened"
  },
  "resource_limits": {
    "cpu_limit": 1.0,
    "memory_limit_mb": 2048,
    "pids_limit": 128
  },
  "domain_policies": [
    {
      "domain": "github.com",
      "description": "GitHub web"
    },
    {
      "domain": "api.github.com",
      "description": "GitHub API - repos, issues, PRs",
      "requests_per_minute": 100,
      "burst_size": 20
    },
    {
      "domain": "raw.githubusercontent.com",
      "description": "GitHub raw content"
    },
    {
      "domain": "objects.githubusercontent.com",
      "description": "GitHub objects"
    },
    {
      "domain": "gitlab.com",
      "description": "GitLab web",
      "read_only": true
    },
    {
      "domain": "*.gitlab.com",
      "description": "GitLab subdomains",
      "read_only": true
    },
    {
      "domain": "pypi.org",
      "description": "Python Package Index",
      "read_only": true
    },
    {
      "domain": "files.pythonhosted.org",
      "description": "Python package downloads",
      "read_only": true
    },
    {
      "domain": "registry.npmjs.org",
      "description": "NPM Registry",
      "read_only": true
    }
  ],
  "dlp": {
    "enabled": true,
    "mode": "block",
    "skip_domains": [],
    "custom_patterns": []
  },
  "email_policies": []
}
